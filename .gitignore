# Build output
bin/
obj/
debug/
release/
*.exe
*.dll
*.pdb
*.cache

# Allow CSS, HTML, and CSV files in bin/Debug (used for Harmonize setup)
!**/bin/Debug/*.css
!**/bin/Debug/*.html
!**/bin/Debug/*.csv

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.csproj.user
UpgradeLog.htm
*.aps

# Database backups (large binary files)
*.bak

# Connection strings (may contain credentials)
connection.txt
connection2023.txt
connectionold.txt
connection_tst.txt

# VSTO keys
*_TemporaryKey.pfx

# Python
__pycache__/
*.pyc
*.pyo

# Web API folder (server-side scripts, logs — not for public repo)
www/api/

# Generated chart data
MyData.js

# Claude Code local settings
.claude/

# Paper drafts (work in progress, not for repo)
paper*.md
paper*.txt
paper*.docx

# OS
Thumbs.db
Desktop.ini
.DS_Store
